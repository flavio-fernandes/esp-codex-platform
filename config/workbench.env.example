# Copy to config/workbench.env and edit for your local setup.
# This file is safe to commit; config/workbench.env is ignored.

# Use a documentation/example IP in committed files. Put your real workbench IP
# or DNS name in config/workbench.env.
WORKBENCH_IP=192.0.2.10
WORKBENCH_USER=pi

# The reset-aware workbench helper defaults to SLOT1 for safety.
ESPWB_SLOT=SLOT1
ALLOW_NON_SLOT1=0

# SSH key discovery. The devcontainer mounts the host SSH directory here by
# default. You can also set ESPWB_SSH_KEY in your ignored local env file if the
# mount is unavailable.
HOST_SSH_DIR=/host-ssh
SSH_CONFIG=/dev/null
# Optional known_hosts file to use instead of ssh-keyscan when the workbench is
# reachable by SSH but keyscan is unreliable during recovery.
# ESPWB_KNOWN_HOSTS=${HOME}/.ssh/known_hosts
# SSH timeout tuning for degraded workbench recovery paths.
ESPWB_SSH_CONNECT_TIMEOUT=10
ESPWB_SSH_SERVER_ALIVE_INTERVAL=5
ESPWB_SSH_SERVER_ALIVE_COUNT_MAX=2

# Derived defaults. Override only if your workbench uses different ports/paths.
WORKBENCH_URL=http://${WORKBENCH_IP}:8080
ESP_PORT=rfc2217://${WORKBENCH_IP}:4001?ign_set_control
RUN_RFC2217_TEST=0
STATIC_ONLY=0

# Workbench API timeout tuning used by status, validation, and recovery checks.
ESPWB_API_CONNECT_TIMEOUT=3
ESPWB_API_MAX_TIME=8
ESPWB_RECOVER_API_MAX_TIME=20

# Optional app-only UF2 transport settings. Keep board-specific labels and
# offsets commented in the generic starter; downstream projects should opt in.
# ESPWB_UF2_VOLUME_LABEL=MAGTAGBOOT
# ESPWB_UF2_MIN_ADDRESS=0x10000
ESPWB_UF2_VERIFY_TIMEOUT=20
ESPWB_UF2_VERIFY_INTERVAL=1

# Portal service name used by the app-only UF2 transport on the workbench.
ESPWB_LOCAL_PORTAL_SERVICE=rfc2217-portal

# Serial monitor guardrails. The monitor exits after this many seconds without
# bytes so post-monitor recovery still runs if the RFC2217 path goes quiet.
# Use 0 only for intentional unbounded live monitoring.
ESPWB_MONITOR_IDLE_TIMEOUT=300
ESPWB_MONITOR_MAX_TIME=0

# Optional local USB/V4L2 camera for visual evidence. Override this with a
# stable /dev/v4l/by-id/... path when the Linux host has multiple cameras.
WORKBENCH_CAMERA_DEVICE=/dev/v4l/by-id/usb-Creative_Technology_Ltd._Live__Cam_Chat_HD_VF0790_2015032504121-video-index0
WORKBENCH_CAMERA_WIDTH=1280
WORKBENCH_CAMERA_HEIGHT=720
WORKBENCH_CAMERA_SKIP=10
