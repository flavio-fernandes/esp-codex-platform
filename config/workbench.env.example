# Copy to config/workbench.env and edit for your local setup.
# This file is safe to commit; config/workbench.env is ignored.

# Use a documentation/example IP in committed files. Put your real workbench IP
# or DNS name in config/workbench.env.
WORKBENCH_IP=192.0.2.10
WORKBENCH_USER=pi

# The reset-aware workbench helper defaults to SLOT1 for safety.
ESPWB_SLOT=SLOT1
ALLOW_NON_SLOT1=0

# SSH key discovery. The devcontainer mounts the host SSH directory here by
# default. You can also set ESPWB_SSH_KEY in your ignored local env file if the
# mount is unavailable.
HOST_SSH_DIR=/host-ssh
SSH_CONFIG=/dev/null

# Derived defaults. Override only if your workbench uses different ports/paths.
WORKBENCH_URL=http://${WORKBENCH_IP}:8080
ESP_PORT=rfc2217://${WORKBENCH_IP}:4001?ign_set_control
RUN_RFC2217_TEST=0

# Optional local USB/V4L2 camera for visual evidence. Override this with a
# stable /dev/v4l/by-id/... path when the Linux host has multiple cameras.
WORKBENCH_CAMERA_DEVICE=/dev/v4l/by-id/usb-Creative_Technology_Ltd._Live__Cam_Chat_HD_VF0790_2015032504121-video-index0
WORKBENCH_CAMERA_WIDTH=1280
WORKBENCH_CAMERA_HEIGHT=720
WORKBENCH_CAMERA_SKIP=10
