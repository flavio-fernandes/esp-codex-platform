{
  "name": "ESPHome workbench",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "ESPHOME_IMAGE": "ghcr.io/esphome/esphome:stable",
      "USERNAME": "vscode",
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode",
  "updateRemoteUserUID": false,
  "containerEnv": {
    "WORKBENCH_USER": "pi",
    "ESPWB_SLOT": "SLOT1",
    "PLATFORMIO_CORE_DIR": "/cache/platformio",
    "PIP_CACHE_DIR": "/cache/pip"
  },
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/host-ssh,type=bind,readonly",
    "source=esphome-workbench-platformio-cache,target=/cache/platformio,type=volume",
    "source=esphome-workbench-pip-cache,target=/cache/pip,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "esphome.esphome-vscode",
        "ms-vscode.vscode-serial-monitor",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true
      }
    }
  }
}
